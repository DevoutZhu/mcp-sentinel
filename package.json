{
  "name": "mcp-sentinel",
  "version": "0.1.0",
  "private": true,
  "description": "Postman for MCP — test, debug, and monitor MCP servers",
  "scripts": {
    "dev": "pnpm --filter @mcp-sentinel/cli dev",
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts,.tsx --ignore-pattern dist --ignore-pattern node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,yml,yaml}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,yml,yaml}\" --ignore-path .gitignore"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "testing",
    "cli",
    "devtools"
  ],
  "author": "Devout Zhu <devoutzt@gmail.com>",
  "license": "Apache-2.0",
  "packageManager": "pnpm@11.15.1",
  "engines": {
    "node": ">=20.0.0"
  },
  "type": "module",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.0",
    "chalk": "^5.4.0",
    "commander": "^13.0.0",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.31.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
